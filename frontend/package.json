{
  "name": "@telemetryflow/viz",
  "version": "1.4.0",
  "description": "TelemetryFlow Core - IAM, AI Assistant & Audit Dashboard",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "vite --mode development",
    "start:debug": "vite --mode development",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' vite build --mode production",
    "build:prod": "NODE_OPTIONS='--max-old-space-size=4096' vite build --mode production",
    "build:dev": "vite build --mode development",
    "build:typecheck": "NODE_OPTIONS='--max-old-space-size=4096' vue-tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "clean": "rm -rf dist node_modules",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.1",
    "@vicons/ionicons5": "^0.12.0",
    "@vueuse/core": "^12.8.2",
    "axios": "^1.16.1",
    "dayjs": "^1.11.19",
    "dompurify": "^3.4.7",
    "echarts": "^5.6.0",
    "lodash-es": "^4.17.22",
    "marked": "^18.0.4",
    "naive-ui": "^2.43.2",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "uuid": "^14.0.0",
    "vue": "^3.5.27",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.19.7",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@unocss/preset-icons": "^66.7.0",
    "@unocss/preset-uno": "^66.7.0",
    "@unocss/transformer-directives": "^66.7.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitejs/plugin-vue-jsx": "^4.2.0",
    "@vitest/ui": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.9.1",
    "fast-check": "^4.5.3",
    "happy-dom": "^20.6.1",
    "jsdom": "^28.1.0",
    "sass": "^1.97.2",
    "typescript": "~5.7.3",
    "unocss": "^66.7.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.14",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
