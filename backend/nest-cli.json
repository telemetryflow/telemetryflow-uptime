{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "assets": [
      { "include": "**/*.hbs", "watchAssets": true }
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/__tests__/**",
    "**/tests/templates/**",
    "src/modules/__legacy__archived/**"
  ]
}
