<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>Weekly Observability Report - TelemetryFlow</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:AllowPNG/>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style>
    :root {
      color-scheme: light dark;
      supported-color-schemes: light dark;
    }

    * {
      -ms-text-size-adjust: 100%;
      -webkit-text-size-adjust: 100%;
    }

    html, body {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      height: 100% !important;
    }

    table, td {
      mso-table-lspace: 0pt !important;
      mso-table-rspace: 0pt !important;
      border-collapse: collapse !important;
    }

    img {
      -ms-interpolation-mode: bicubic;
      border: 0;
      height: auto;
      line-height: 100%;
      outline: none;
      text-decoration: none;
    }

    a {
      text-decoration: none;
    }

    .info-box {
      background-color: #f0fdfa;
      border: 1px solid #99f6e4;
      border-left: 4px solid #0d9488;
      border-radius: 0 6px 6px 0;
    }

    .info-box td {
      color: #0f766e;
    }

    .success-box {
      background-color: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-left: 4px solid #16a34a;
      border-radius: 0 6px 6px 0;
    }

    .success-box td {
      color: #166534;
    }

    .alert-box {
      background-color: #fffbeb;
      border: 1px solid #fde68a;
      border-left: 4px solid #f59e0b;
      border-radius: 0 6px 6px 0;
    }

    .alert-box td {
      color: #92400e;
    }

    .danger-box {
      background-color: #fef2f2;
      border: 1px solid #fecaca;
      border-left: 4px solid #ef4444;
      border-radius: 0 6px 6px 0;
    }

    .danger-box td {
      color: #991b1b;
    }

    @media (prefers-color-scheme: dark) {
      .email-bg { background-color: #0f172a !important; }
      .email-container { background-color: #1e293b !important; }
      .email-heading { color: #f1f5f9 !important; }
      .email-text { color: #cbd5e1 !important; }
      .email-text-muted { color: #94a3b8 !important; }
      .email-divider { border-color: #334155 !important; }
      .email-footer-text { color: #64748b !important; }
      .email-footer-link { color: #94a3b8 !important; }
      .info-box { background-color: #042f2e !important; border-color: #115e59 !important; }
      .info-box td { color: #5eead4 !important; }
      .success-box { background-color: #052e16 !important; border-color: #166534 !important; }
      .success-box td { color: #86efac !important; }
      .alert-box { background-color: #451a03 !important; border-color: #92400e !important; }
      .alert-box td { color: #fcd34d !important; }
      .danger-box { background-color: #450a0a !important; border-color: #991b1b !important; }
      .danger-box td { color: #fca5a5 !important; }
      .detail-row-bg { background-color: #1e293b !important; border-color: #334155 !important; }
      .detail-row-alt { background-color: #0f172a !important; }
      .detail-label { color: #94a3b8 !important; }
      .detail-value { color: #f1f5f9 !important; }
      .metrics-header { background-color: #0f172a !important; border-color: #334155 !important; }
      .metrics-header-text { color: #f1f5f9 !important; }
      .link-fallback { color: #2dd4bf !important; }
      .bar-track { background-color: #334155 !important; }
    }

    [data-ogsc] .email-bg { background-color: #0f172a !important; }
    [data-ogsc] .email-container { background-color: #1e293b !important; }
    [data-ogsc] .email-heading { color: #f1f5f9 !important; }
    [data-ogsc] .email-text { color: #cbd5e1 !important; }
    [data-ogsc] .email-text-muted { color: #94a3b8 !important; }

    @media only screen and (max-width: 620px) {
      .email-container {
        width: 100% !important;
        max-width: 100% !important;
      }
      .email-padding {
        padding-left: 24px !important;
        padding-right: 24px !important;
      }
      .email-stack {
        display: block !important;
        width: 100% !important;
      }
      .email-heading {
        font-size: 22px !important;
      }
      .btn-full-width {
        display: block !important;
        width: 100% !important;
        text-align: center !important;
      }
    }
  </style>
</head>
<body style="margin:0; padding:0; word-spacing:normal; background-color:#f1f5f9;">
  <div role="article" aria-roledescription="email" aria-label="Weekly Observability Report" lang="en" style="font-size:16px; font-size:1rem; font-size:max(16px,1rem);">

    <!--[if mso]>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f1f5f9;">
    <tr><td align="center">
    <![endif]-->

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-bg" style="background-color:#f1f5f9;">
      <tr>
        <td align="center" style="padding:40px 16px;">

          <!--[if mso]>
          <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0">
          <tr><td>
          <![endif]-->

          <table role="presentation" class="email-container" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:800px; width:100%; background-color:#ffffff; border-radius:12px; overflow:hidden; box-shadow:0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1);">

            <!-- HEADER WITH LOGO -->
            <tr>
              <td align="center" class="email-padding" style="padding:32px 40px 24px 40px; background-color:#ffffff;">
                <!--[if !mso]><!-->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 60" width="280" height="60" style="display:block; margin:0 auto;">
                  <g transform="translate(0,2)">
                    <g stroke="#0d9488" stroke-width="3" stroke-linecap="round">
                      <line x1="28" y1="28" x2="28" y2="8"/>
                      <line x1="28" y1="28" x2="42" y2="14"/>
                      <line x1="28" y1="28" x2="48" y2="28"/>
                      <line x1="28" y1="28" x2="42" y2="42"/>
                      <line x1="28" y1="28" x2="28" y2="48"/>
                      <line x1="28" y1="28" x2="14" y2="42"/>
                      <line x1="28" y1="28" x2="8" y2="28"/>
                      <line x1="28" y1="28" x2="14" y2="14"/>
                    </g>
                    <g fill="none" stroke="#f97316" stroke-width="2.5">
                      <circle cx="28" cy="8" r="5"/>
                      <circle cx="42" cy="14" r="5"/>
                      <circle cx="48" cy="28" r="5"/>
                      <circle cx="42" cy="42" r="5"/>
                      <circle cx="28" cy="48" r="5"/>
                      <circle cx="14" cy="42" r="5"/>
                      <circle cx="8" cy="28" r="5"/>
                      <circle cx="14" cy="14" r="5"/>
                    </g>
                    <circle cx="28" cy="28" r="9" fill="none" stroke="#0d9488" stroke-width="3"/>
                    <line x1="23" y1="23" x2="33" y2="33" stroke="#0d9488" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="33" y1="23" x2="23" y2="33" stroke="#0d9488" stroke-width="2.5" stroke-linecap="round"/>
                  </g>
                  <text x="64" y="30" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="22" font-weight="800" fill="#0f172a">TelemetryFlow</text>
                  <text x="64" y="46" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="8" font-weight="600" fill="#0d9488" letter-spacing="3">OBSERVABILITY PLATFORM</text>
                </svg>
                <!--<![endif]-->
                <!--[if mso]>
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding-right:12px; vertical-align:middle;">
                    <img src="{{logoUrl}}" width="333" height="90" alt="{{appName}}" style="display:block; border-radius:8px;" border="0">
                  </td>
                  <td style="vertical-align:middle;">
                    <span style="font-family:'Segoe UI',Roboto,sans-serif; font-size:22px; font-weight:800; color:#0f172a;">TelemetryFlow</span><br/>
                    <span style="font-family:'Segoe UI',Roboto,sans-serif; font-size:8px; font-weight:600; color:#0d9488; letter-spacing:3px;">OBSERVABILITY PLATFORM</span>
                  </td>
                </tr>
                </table>
                <![endif]-->
              </td>
            </tr>

            <!-- DIVIDER -->
            <tr>
              <td class="email-padding" style="padding:0 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr><td class="email-divider" style="border-top:1px solid #e2e8f0; font-size:1px; line-height:1px;">&nbsp;</td></tr>
                </table>
              </td>
            </tr>

            <!-- HEADING -->
            <tr>
              <td align="center" class="email-padding" style="padding:32px 40px 8px 40px;">
                <h1 class="email-heading" style="margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:26px; font-weight:700; color:#0f172a; line-height:1.3;">
                  Weekly Observability Report
                </h1>
              </td>
            </tr>

            <!-- GREETING -->
            <tr>
              <td class="email-padding" style="padding:16px 40px 0 40px;">
                <p class="email-text" style="margin:0 0 20px 0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:16px; line-height:1.6; color:#475569;">
                  Hi {{firstName}} {{lastName}},
                </p>
                <p class="email-text" style="margin:0 0 24px 0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:16px; line-height:1.6; color:#475569;">
                  Here's your weekly observability report for {{periodRange}}.
                </p>
              </td>
            </tr>

            <!-- REPORT PERIOD INFO BOX -->
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="info-box" style="background-color:#f0fdfa; border:1px solid #99f6e4; border-left:4px solid #0d9488; border-radius:0 6px 6px 0;">
                  <tr>
                    <td style="padding:16px 20px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; line-height:1.5; color:#0f766e;">
                      <strong>Report Period:</strong> {{periodRange}} &nbsp;|&nbsp; <strong>Generated:</strong> {{generatedAt}}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- 7-DAY UPTIME BAR CHART -->
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #e2e8f0; border-radius:8px; overflow:hidden;">
                  <!-- Section Header -->
                  <tr>
                    <td class="metrics-header" style="background-color:#f8fafc; padding:12px 20px; border-bottom:1px solid #e2e8f0;">
                      <h3 class="metrics-header-text" style="margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; font-weight:700; color:#0f172a; text-transform:uppercase; letter-spacing:0.5px;">7-Day Uptime Trend</h3>
                    </td>
                  </tr>
                  <!-- Bar Chart -->
                  <tr>
                    <td class="detail-row-bg" style="padding:20px;">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:16px 0;">
                        <!-- Bars -->
                        <tr>
                          {{#each weeklyBars}}
                          <td align="center" valign="bottom" style="padding:0 4px; width:14.28%;">
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" width="100%">
                              <tr><td style="height:{{subtract 80 barHeightPx}}px;">&nbsp;</td></tr>
                              <tr><td style="height:{{barHeightPx}}px; background-color:{{barColor}}; border-radius:4px 4px 0 0;">&nbsp;</td></tr>
                            </table>
                          </td>
                          {{/each}}
                        </tr>
                        <!-- Day Labels -->
                        <tr>
                          {{#each weeklyBars}}
                          <td align="center" style="padding:6px 4px 0; font-size:11px; font-weight:600; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{dayLabel}}</td>
                          {{/each}}
                        </tr>
                        <!-- Date Labels -->
                        <tr>
                          {{#each weeklyBars}}
                          <td align="center" style="padding:2px 4px; font-size:10px; color:#94a3b8; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{date}}</td>
                          {{/each}}
                        </tr>
                        <!-- Incident Counts -->
                        <tr>
                          {{#each weeklyBars}}
                          <td align="center" style="padding:4px 4px 0; font-size:10px; color:#94a3b8; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                            {{#if (gt incidentCount "0")}}<span style="color:#d97706;">{{incidentCount}} inc</span>{{/if}}
                          </td>
                          {{/each}}
                        </tr>
                      </table>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- WEEK-OVER-WEEK COMPARISON TABLE -->
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #e2e8f0; border-radius:8px; overflow:hidden;">
                  <!-- Table Header -->
                  <tr>
                    <td class="metrics-header" style="background-color:#f8fafc; padding:12px 20px; border-bottom:1px solid #e2e8f0;">
                      <h3 class="metrics-header-text" style="margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; font-weight:700; color:#0f172a; text-transform:uppercase; letter-spacing:0.5px;">Week-over-Week</h3>
                    </td>
                  </tr>
                  <!-- Column Headers -->
                  <tr>
                    <td class="detail-row-bg" style="padding:10px 20px; border-bottom:1px solid #e2e8f0;">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td width="30%" style="font-size:12px; font-weight:700; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; text-transform:uppercase; letter-spacing:0.3px;">Metric</td>
                          <td width="22%" style="font-size:12px; font-weight:700; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; text-transform:uppercase; letter-spacing:0.3px;">This Week</td>
                          <td width="22%" style="font-size:12px; font-weight:700; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; text-transform:uppercase; letter-spacing:0.3px;">Last Week</td>
                          <td width="26%" style="font-size:12px; font-weight:700; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; text-transform:uppercase; letter-spacing:0.3px; text-align:right;">Change</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                  <!-- Comparison Rows -->
                  {{#each comparisonMetrics}}
                  <tr>
                    <td class="detail-row-bg{{#if (eq (mod @index 2) 1)}} detail-row-alt{{/if}}" style="padding:12px 20px; border-bottom:1px solid #e2e8f0;{{#if (eq (mod @index 2) 1)}} background-color:#f8fafc;{{/if}}">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td class="detail-label" width="30%" style="font-size:13px; font-weight:500; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{label}}</td>
                          <td class="detail-value" width="22%" style="font-size:14px; font-weight:700; color:#1e293b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{thisWeek}}</td>
                          <td class="detail-value" width="22%" style="font-size:14px; font-weight:700; color:#1e293b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{lastWeek}}</td>
                          <td width="26%" style="font-size:13px; font-weight:600; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; text-align:right;">
                            {{#if isPositiveChange}}
                            <span style="color:#16a34a;">&#9650; {{changePercent}}</span>
                            {{else}}
                            <span style="color:#dc2626;">&#9660; {{changePercent}}</span>
                            {{/if}}
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                  {{/each}}
                </table>
              </td>
            </tr>

            <!-- INCIDENT TIMELINE (conditional) -->
            {{#if hasIncidents}}
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #e2e8f0; border-radius:8px; overflow:hidden;">
                  <!-- Section Header -->
                  <tr>
                    <td class="metrics-header" style="background-color:#f8fafc; padding:12px 20px; border-bottom:1px solid #e2e8f0;">
                      <h3 class="metrics-header-text" style="margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; font-weight:700; color:#0f172a; text-transform:uppercase; letter-spacing:0.5px;">Daily Incident Count</h3>
                    </td>
                  </tr>
                  <!-- Incident Bars -->
                  {{#each incidentTimeline}}
                  <tr>
                    <td class="detail-row-bg" style="padding:6px 20px; border-bottom:1px solid #e2e8f0;">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td class="detail-label" width="50" style="font-size:12px; font-weight:500; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{dayLabel}}</td>
                          <td style="padding:6px 8px;">
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                              <tr>
                                <td style="width:{{barWidthPercent}}%; height:14px; background-color:#d97706; border-radius:3px;">&nbsp;</td>
                                <td>&nbsp;</td>
                              </tr>
                            </table>
                          </td>
                          <td class="detail-value" width="40" style="text-align:right; font-size:13px; font-weight:700; color:#1e293b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{count}}</td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                  {{/each}}
                </table>
              </td>
            </tr>
            {{/if}}

            <!-- SERVICE PERFORMANCE TABLE -->
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #e2e8f0; border-radius:8px; overflow:hidden;">
                  <!-- Section Header -->
                  <tr>
                    <td class="metrics-header" style="background-color:#f8fafc; padding:12px 20px; border-bottom:1px solid #e2e8f0;">
                      <h3 class="metrics-header-text" style="margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; font-weight:700; color:#0f172a; text-transform:uppercase; letter-spacing:0.5px;">Service Performance</h3>
                    </td>
                  </tr>
                  <!-- Service Rows -->
                  {{#each performanceSummary}}
                  <tr>
                    <td class="detail-row-bg{{#if (eq (mod @index 2) 1)}} detail-row-alt{{/if}}" style="padding:12px 20px; border-bottom:1px solid #e2e8f0;{{#if (eq (mod @index 2) 1)}} background-color:#f8fafc;{{/if}}">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td width="120" style="font-size:13px; font-weight:700; color:#1e293b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; vertical-align:top; padding-top:2px;">{{serviceName}}</td>
                          <td style="padding:0 12px;">
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                              <tr>
                                <td style="padding-bottom:2px;">
                                  {{{uptimeMiniBars uptimeBarWidth wide=true}}}
                                </td>
                              </tr>
                            </table>
                            <p style="margin:2px 0 0 0; font-size:10px; font-weight:600; color:{{uptimeBarColor}}; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{uptime}}</p>
                          </td>
                          <td width="100" style="padding:0 0 0 12px;">
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                              <tr>
                                <td class="bar-track" style="background-color:#e2e8f0; border-radius:3px; height:12px;">
                                  <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="width:{{responseTimeBarWidth}}%;">
                                    <tr><td style="height:12px; background-color:{{responseTimeColor}}; border-radius:3px;">&nbsp;</td></tr>
                                  </table>
                                </td>
                              </tr>
                            </table>
                            <p style="margin:2px 0 0 0; font-size:10px; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{avgResponseTime}}</p>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                  {{/each}}
                </table>
              </td>
            </tr>

            <!-- CTA BUTTON -->
            <tr>
              <td align="center" class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td align="center" style="background-color:#0d9488; border-radius:8px;">
                      <!--[if mso]>
                      <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{reportLink}}" style="height:50px; v-text-anchor:middle; width:260px;" arcsize="16%" strokecolor="#0d9488" fillcolor="#0d9488">
                      <w:anchorlock/>
                      <center style="font-family:'Segoe UI',Roboto,sans-serif; font-size:16px; font-weight:700; color:#ffffff;">View Full Report</center>
                      </v:roundrect>
                      <![endif]-->
                      <!--[if !mso]><!-->
