<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>Your Verification Code - TelemetryFlow</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:AllowPNG/>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style>
    :root {
      color-scheme: light dark;
      supported-color-schemes: light dark;
    }

    body, table, td, a {
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
    }
    table, td {
      mso-table-lspace: 0pt;
      mso-table-rspace: 0pt;
    }
    img {
      -ms-interpolation-mode: bicubic;
      border: 0;
      height: auto;
      line-height: 100%;
      outline: none;
      text-decoration: none;
    }
    body {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      background-color: #f1f5f9;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    .info-box {
      background-color: #f0fdfa;
      border: 1px solid #99f6e4;
      border-left: 4px solid #0d9488;
      border-radius: 0 6px 6px 0;
    }
    .success-box {
      background-color: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-left: 4px solid #16a34a;
      border-radius: 0 6px 6px 0;
    }
    .alert-box {
      background-color: #fffbeb;
      border: 1px solid #fde68a;
      border-left: 4px solid #d97706;
      border-radius: 0 6px 6px 0;
    }
    .danger-box {
      background-color: #fef2f2;
      border: 1px solid #fecaca;
      border-left: 4px solid #dc2626;
      border-radius: 0 6px 6px 0;
    }

    @media (prefers-color-scheme: dark) {
      body, .body-bg {
        background-color: #0f172a !important;
      }
      .email-container {
        background-color: #1e293b !important;
      }
      .header-bg {
        background-color: #0f172a !important;
      }
      h1, h2, h3, .heading-text {
        color: #f1f5f9 !important;
      }
      .body-text, p {
        color: #cbd5e1 !important;
      }
      .otp-panel {
        background-color: #042f2e !important;
        border-color: #115e59 !important;
      }
      .otp-code-text {
        color: #5eead4 !important;
        background-color: #0f172a !important;
        border-color: #115e59 !important;
      }
      .purpose-panel {
        background-color: #0f172a !important;
      }
      .purpose-label {
        color: #94a3b8 !important;
      }
      .purpose-value {
        color: #e2e8f0 !important;
      }
      .info-box {
        background-color: #042f2e !important;
        border-color: #115e59 !important;
        border-left-color: #0d9488 !important;
      }
      .info-box-text {
        color: #5eead4 !important;
      }
      .alert-box {
        background-color: #451a03 !important;
        border-color: #78350f !important;
        border-left-color: #d97706 !important;
      }
      .alert-box-text {
        color: #fde68a !important;
      }
      .danger-box {
        background-color: #450a0a !important;
        border-color: #7f1d1d !important;
        border-left-color: #dc2626 !important;
      }
      .danger-box-text {
        color: #fca5a5 !important;
      }
      .expiry-badge-dark {
        background-color: #450a0a !important;
        color: #fca5a5 !important;
      }
      .footer-text {
        color: #64748b !important;
      }
      .footer-link {
        color: #0d9488 !important;
      }
      .footer-border {
        border-top-color: #334155 !important;
      }
    }

    @media only screen and (max-width: 620px) {
      .email-container {
        width: 100% !important;
        max-width: 100% !important;
      }
      .email-padding {
        padding-left: 20px !important;
        padding-right: 20px !important;
      }
      .header-padding {
        padding: 24px 20px !important;
      }
      .otp-code-text {
        font-size: 32px !important;
        letter-spacing: 6px !important;
        padding: 16px 24px !important;
      }
      .otp-panel {
        padding: 20px !important;
      }
    }
  </style>
</head>
<body style="margin:0; padding:0; background-color:#f1f5f9;">
  <!--[if mso]>
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f1f5f9;">
  <tr><td align="center">
  <![endif]-->

  <table role="presentation" class="body-bg" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f1f5f9;">
    <tr>
      <td align="center" style="padding: 24px 16px;">

        <!-- Email Container -->
        <!--[if mso]>
        <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="width:600px;">
        <tr><td>
        <![endif]-->
        <table role="presentation" class="email-container" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:800px; background-color:#ffffff; border-radius:12px; overflow:hidden; box-shadow:0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05);">

          <!-- Header with Logo -->
          <tr>
            <td class="header-bg header-padding" align="center" style="background-color:#0f172a; padding:32px 40px;">
              <!--[if mso]>
              <table role="presentation" cellpadding="0" cellspacing="0" border="0"><tr><td style="font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                <span style="font-size:22px; font-weight:800; color:#ffffff;">TelemetryFlow</span><br/>
                <span style="font-size:8px; font-weight:600; color:#0d9488; letter-spacing:3px;">OBSERVABILITY PLATFORM</span>
              </td></tr></table>
              <![endif]-->
              <!--[if !mso]><!-->
              <img src="{{logoUrl}}" width="333" height="90" alt="{{appName}}" style="display:block; border-radius:8px;" border="0">
              <!--<![endif]-->
            </td>
          </tr>

          <!-- Accent Bar -->
          <tr>
            <td style="background: linear-gradient(90deg, #0d9488, #f97316); height:4px; font-size:0; line-height:0;">&nbsp;</td>
          </tr>

          <!-- Body Content -->
          <tr>
            <td class="email-padding" style="padding:40px;">

              <!-- Heading -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td align="center" style="padding-bottom:8px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" style="width:56px; height:56px; background-color:#f0fdfa; border-radius:50%;" valign="middle">
                          <!--[if mso]>
                          <span style="font-size:28px; color:#0d9488;">&#128274;</span>
                          <![endif]-->
                          <!--[if !mso]><!-->
                          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                            <circle cx="12" cy="16" r="1"/>
                          </svg>
                          <!--<![endif]-->
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-bottom:24px;">
                    <h1 class="heading-text" style="margin:0; font-size:26px; font-weight:700; color:#0f172a; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">Your Verification Code</h1>
                  </td>
                </tr>
              </table>

              <!-- Greeting -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="body-text" style="font-size:15px; line-height:1.6; color:#475569; padding-bottom:8px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                    Hi {{firstName}} {{lastName}},
                  </td>
                </tr>
                <tr>
                  <td class="body-text" style="font-size:15px; line-height:1.6; color:#475569; padding-bottom:24px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                    Use the following one-time password (OTP) to complete your verification. Enter this code in the verification field on the TelemetryFlow Platform.
                  </td>
                </tr>
              </table>

              <!-- OTP Code Display -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td class="otp-panel" align="center" style="background-color:#f0fdfa; border:2px solid #99f6e4; border-radius:12px; padding:32px 24px;">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center" style="padding-bottom:12px;">
                          <span class="body-text" style="font-size:12px; font-weight:600; color:#64748b; text-transform:uppercase; letter-spacing:2px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">One-Time Password</span>
                        </td>
                      </tr>
                      <tr>
                        <td align="center">
                          <!--[if mso]>
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td align="center" style="background-color:#0d9488; padding:16px 40px; border-radius:8px;">
                                <span style="font-family:'Courier New',monospace; font-size:36px; font-weight:700; color:#ffffff; letter-spacing:10px;">{{otpCode}}</span>
                              </td>
                            </tr>
                          </table>
                          <![endif]-->
                          <!--[if !mso]><!-->
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td class="otp-code-text" align="center" style="background-color:#0d9488; padding:18px 48px; border-radius:8px; border:2px solid #0d9488;">
                                <span style="font-family:'Courier New',Consolas,'Liberation Mono',monospace; font-size:38px; font-weight:700; color:#ffffff; letter-spacing:10px; line-height:1;">{{otpCode}}</span>
                              </td>
                            </tr>
                          </table>
                          <!--<![endif]-->
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Purpose Info -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td class="purpose-panel" style="background-color:#f8fafc; border-radius:8px; padding:16px 20px;" align="center">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td align="center">
                          <span class="purpose-label" style="font-size:12px; font-weight:600; color:#64748b; text-transform:uppercase; letter-spacing:1px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">Purpose</span>
                        </td>
                      </tr>
                      <tr>
                        <td align="center" style="padding-top:4px;">
                          <span class="purpose-value" style="font-size:15px; font-weight:600; color:#0f172a; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{purpose}}</span>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Expiration Alert Box (red badge style) -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td align="center">
                    <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                      <tr>
                        <td class="expiry-badge-dark" align="center" style="background-color:#fef2f2; border:1px solid #fecaca; border-radius:24px; padding:10px 24px;">
                          <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                              <td valign="middle" style="padding-right:8px;">
                                <!--[if mso]>
                                <span style="font-size:14px; color:#dc2626;">&#9201;</span>
                                <![endif]-->
                                <!--[if !mso]><!-->
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                  <circle cx="12" cy="12" r="10"/>
                                  <polyline points="12 6 12 12 16 14"/>
                                </svg>
                                <!--<![endif]-->
                              </td>
                              <td valign="middle">
                                <span style="font-size:14px; font-weight:600; color:#dc2626; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">Expires in {{expirationMinutes}} minutes</span>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>

              <!-- Phishing Warning - Alert Box -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:16px;">
                <tr>
                  <td class="alert-box" style="padding:16px 20px;">
                    <p class="alert-box-text" style="margin:0; font-size:14px; line-height:1.6; color:#92400e; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                      <strong>Phishing Warning:</strong> TelemetryFlow will never ask you for this code via phone, email reply, or chat. If someone asks for this code, it is a phishing attempt. Report it immediately.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Never Share Notice - Danger Box -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:24px;">
                <tr>
                  <td class="danger-box" style="padding:16px 20px;">
                    <p class="danger-box-text" style="margin:0; font-size:14px; line-height:1.6; color:#991b1b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                      <strong>Never share this code.</strong> TelemetryFlow employees will never ask for your verification code. Do not share it with anyone, including anyone claiming to be from our support team.
                    </p>
                  </td>
                </tr>
              </table>

              <!-- Closing -->
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="body-text" style="font-size:15px; line-height:1.6; color:#475569; padding-bottom:16px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                    If you did not request this code, you can safely ignore this email. Someone may have entered your email address by mistake.
                  </td>
                </tr>
                <tr>
                  <td class="body-text" style="font-size:15px; line-height:1.6; color:#475569; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                    Stay secure,<br>
                    <strong style="color:#0f172a;">TelemetryFlow Observability - Team</strong>
                  </td>
                </tr>
              </table>

            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td class="email-padding" style="padding:0 40px 32px 40px;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td class="footer-border" style="border-top:1px solid #e2e8f0; padding-top:24px;" align="center">
                    <p class="footer-text" style="margin:0 0 8px 0; font-size:12px; line-height:1.5; color:#94a3b8; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                      &copy; {{year}} TelemetryFlow Observability. All rights reserved.
                    </p>
                    <p class="footer-text" style="margin:0 0 8px 0; font-size:12px; line-height:1.5; color:#94a3b8; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                      This is an automated message. Please do not reply to this email.
                    </p>
                    <p class="footer-text" style="margin:0; font-size:12px; line-height:1.5; color:#94a3b8; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                      <a class="footer-link" href="https://telemetryflow.id" style="color:#0d9488; text-decoration:underline;">telemetryflow.id</a>
                    </p>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
        <!--[if mso]>
        </td></tr></table>
        <![endif]-->

      </td>
    </tr>
  </table>

  <!--[if mso]>
  </td></tr></table>
  <![endif]-->
</body>
</html>
