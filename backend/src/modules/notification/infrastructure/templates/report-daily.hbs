<!DOCTYPE html>
<html lang="en" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <meta name="color-scheme" content="light dark">
  <meta name="supported-color-schemes" content="light dark">
  <title>Daily Observability Report - TelemetryFlow</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:AllowPNG/>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style>
    :root {
      color-scheme: light dark;
      supported-color-schemes: light dark;
    }

    * {
      -ms-text-size-adjust: 100%;
      -webkit-text-size-adjust: 100%;
    }

    html, body {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      height: 100% !important;
    }

    table, td {
      mso-table-lspace: 0pt !important;
      mso-table-rspace: 0pt !important;
      border-collapse: collapse !important;
    }

    img {
      -ms-interpolation-mode: bicubic;
      border: 0;
      height: auto;
      line-height: 100%;
      outline: none;
      text-decoration: none;
    }

    a {
      text-decoration: none;
    }

    .info-box {
      background-color: #f0fdfa;
      border: 1px solid #99f6e4;
      border-left: 4px solid #0d9488;
      border-radius: 0 6px 6px 0;
    }

    .info-box td {
      color: #0f766e;
    }

    .success-box {
      background-color: #f0fdf4;
      border: 1px solid #bbf7d0;
      border-left: 4px solid #16a34a;
      border-radius: 0 6px 6px 0;
    }

    .success-box td {
      color: #166534;
    }

    .alert-box {
      background-color: #fffbeb;
      border: 1px solid #fde68a;
      border-left: 4px solid #f59e0b;
      border-radius: 0 6px 6px 0;
    }

    .alert-box td {
      color: #92400e;
    }

    .danger-box {
      background-color: #fef2f2;
      border: 1px solid #fecaca;
      border-left: 4px solid #ef4444;
      border-radius: 0 6px 6px 0;
    }

    .danger-box td {
      color: #991b1b;
    }

    @media (prefers-color-scheme: dark) {
      .email-bg { background-color: #0f172a !important; }
      .email-container { background-color: #1e293b !important; }
      .email-heading { color: #f1f5f9 !important; }
      .email-text { color: #cbd5e1 !important; }
      .email-text-muted { color: #94a3b8 !important; }
      .email-divider { border-color: #334155 !important; }
      .email-footer-text { color: #64748b !important; }
      .email-footer-link { color: #94a3b8 !important; }
      .info-box { background-color: #042f2e !important; border-color: #115e59 !important; }
      .info-box td { color: #5eead4 !important; }
      .success-box { background-color: #052e16 !important; border-color: #166534 !important; }
      .success-box td { color: #86efac !important; }
      .alert-box { background-color: #451a03 !important; border-color: #92400e !important; }
      .alert-box td { color: #fcd34d !important; }
      .danger-box { background-color: #450a0a !important; border-color: #991b1b !important; }
      .danger-box td { color: #fca5a5 !important; }
      .detail-row-bg { background-color: #1e293b !important; border-color: #334155 !important; }
      .detail-row-alt { background-color: #0f172a !important; }
      .detail-label { color: #94a3b8 !important; }
      .detail-value { color: #f1f5f9 !important; }
      .metrics-header { background-color: #0f172a !important; border-color: #334155 !important; }
      .metrics-header-text { color: #f1f5f9 !important; }
      .link-fallback { color: #2dd4bf !important; }
      .gauge-text { color: #f1f5f9 !important; }
      .gauge-label { color: #94a3b8 !important; }
      .status-up-bg { background-color: #052e16 !important; }
      .status-down-bg { background-color: #450a0a !important; }
      .status-degraded-bg { background-color: #451a03 !important; }
      .bar-track { background-color: #334155 !important; }
    }

    [data-ogsc] .email-bg { background-color: #0f172a !important; }
    [data-ogsc] .email-container { background-color: #1e293b !important; }
    [data-ogsc] .email-heading { color: #f1f5f9 !important; }
    [data-ogsc] .email-text { color: #cbd5e1 !important; }
    [data-ogsc] .email-text-muted { color: #94a3b8 !important; }
    [data-ogsc] .gauge-text { color: #f1f5f9 !important; }
    [data-ogsc] .gauge-label { color: #94a3b8 !important; }
    [data-ogsc] .status-up-bg { background-color: #052e16 !important; }
    [data-ogsc] .status-down-bg { background-color: #450a0a !important; }
    [data-ogsc] .status-degraded-bg { background-color: #451a03 !important; }
    [data-ogsc] .bar-track { background-color: #334155 !important; }

    @media only screen and (max-width: 620px) {
      .email-container {
        width: 100% !important;
        max-width: 100% !important;
      }
      .email-padding {
        padding-left: 24px !important;
        padding-right: 24px !important;
      }
      .email-stack {
        display: block !important;
        width: 100% !important;
      }
      .email-heading {
        font-size: 22px !important;
      }
      .btn-full-width {
        display: block !important;
        width: 100% !important;
        text-align: center !important;
      }
    }
  </style>
</head>
<body style="margin:0; padding:0; word-spacing:normal; background-color:#f1f5f9;">
  <div role="article" aria-roledescription="email" aria-label="Daily Observability Report" lang="en" style="font-size:16px; font-size:1rem; font-size:max(16px,1rem);">

    <!--[if mso]>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f1f5f9;">
    <tr><td align="center">
    <![endif]-->

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="email-bg" style="background-color:#f1f5f9;">
      <tr>
        <td align="center" style="padding:40px 16px;">

          <!--[if mso]>
          <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0">
          <tr><td>
          <![endif]-->

          <table role="presentation" class="email-container" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width:800px; width:100%; background-color:#ffffff; border-radius:12px; overflow:hidden; box-shadow:0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1);">

            <!-- HEADER WITH LOGO -->
            <tr>
              <td align="center" class="email-padding" style="padding:32px 40px 24px 40px; background-color:#ffffff;">
                <!--[if !mso]><!-->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 60" width="280" height="60" style="display:block; margin:0 auto;">
                  <g transform="translate(0,2)">
                    <g stroke="#0d9488" stroke-width="3" stroke-linecap="round">
                      <line x1="28" y1="28" x2="28" y2="8"/>
                      <line x1="28" y1="28" x2="42" y2="14"/>
                      <line x1="28" y1="28" x2="48" y2="28"/>
                      <line x1="28" y1="28" x2="42" y2="42"/>
                      <line x1="28" y1="28" x2="28" y2="48"/>
                      <line x1="28" y1="28" x2="14" y2="42"/>
                      <line x1="28" y1="28" x2="8" y2="28"/>
                      <line x1="28" y1="28" x2="14" y2="14"/>
                    </g>
                    <g fill="none" stroke="#f97316" stroke-width="2.5">
                      <circle cx="28" cy="8" r="5"/>
                      <circle cx="42" cy="14" r="5"/>
                      <circle cx="48" cy="28" r="5"/>
                      <circle cx="42" cy="42" r="5"/>
                      <circle cx="28" cy="48" r="5"/>
                      <circle cx="14" cy="42" r="5"/>
                      <circle cx="8" cy="28" r="5"/>
                      <circle cx="14" cy="14" r="5"/>
                    </g>
                    <circle cx="28" cy="28" r="9" fill="none" stroke="#0d9488" stroke-width="3"/>
                    <line x1="23" y1="23" x2="33" y2="33" stroke="#0d9488" stroke-width="2.5" stroke-linecap="round"/>
                    <line x1="33" y1="23" x2="23" y2="33" stroke="#0d9488" stroke-width="2.5" stroke-linecap="round"/>
                  </g>
                  <text x="64" y="30" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="22" font-weight="800" fill="#0f172a">TelemetryFlow</text>
                  <text x="64" y="46" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif" font-size="8" font-weight="600" fill="#0d9488" letter-spacing="3">OBSERVABILITY PLATFORM</text>
                </svg>
                <!--<![endif]-->
                <!--[if mso]>
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td style="padding-right:12px; vertical-align:middle;">
                    <img src="{{logoUrl}}" width="333" height="90" alt="{{appName}}" style="display:block; border-radius:8px;" border="0">
                  </td>
                  <td style="vertical-align:middle;">
                    <span style="font-family:'Segoe UI',Roboto,sans-serif; font-size:22px; font-weight:800; color:#0f172a;">TelemetryFlow</span><br/>
                    <span style="font-family:'Segoe UI',Roboto,sans-serif; font-size:8px; font-weight:600; color:#0d9488; letter-spacing:3px;">OBSERVABILITY PLATFORM</span>
                  </td>
                </tr>
                </table>
                <![endif]-->
              </td>
            </tr>

            <!-- DIVIDER -->
            <tr>
              <td class="email-padding" style="padding:0 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                  <tr><td class="email-divider" style="border-top:1px solid #e2e8f0; font-size:1px; line-height:1px;">&nbsp;</td></tr>
                </table>
              </td>
            </tr>

            <!-- HEADING -->
            <tr>
              <td align="center" class="email-padding" style="padding:32px 40px 8px 40px;">
                <h1 class="email-heading" style="margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:26px; font-weight:700; color:#0f172a; line-height:1.3;">
                  Daily Observability Report
                </h1>
              </td>
            </tr>

            <!-- GREETING -->
            <tr>
              <td class="email-padding" style="padding:16px 40px 0 40px;">
                <p class="email-text" style="margin:0 0 20px 0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:16px; line-height:1.6; color:#475569;">
                  Hi {{firstName}} {{lastName}},
                </p>
                <p class="email-text" style="margin:0 0 24px 0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:16px; line-height:1.6; color:#475569;">
                  Here's your daily observability snapshot for {{periodRange}}.
                </p>
              </td>
            </tr>

            <!-- REPORT PERIOD INFO BOX -->
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="info-box" style="background-color:#f0fdfa; border:1px solid #99f6e4; border-left:4px solid #0d9488; border-radius:0 6px 6px 0;">
                  <tr>
                    <td style="padding:16px 20px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; line-height:1.5; color:#0f766e;">
                      <strong>Report Period:</strong> {{periodRange}} | <strong>Generated:</strong> {{generatedAt}}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- SVG UPTIME GAUGE RING -->
            <tr>
              <td align="center" class="email-padding" style="padding:0 40px 24px 40px;">
                <!--[if !mso]><!-->
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 120 120" width="120" height="120" style="display:block; margin:0 auto;">
                  <circle cx="60" cy="60" r="45" fill="none" stroke="#e2e8f0" stroke-width="10"/>
                  <circle cx="60" cy="60" r="45" fill="none" stroke="{{uptimeStrokeColor}}" stroke-width="10"
                    stroke-dasharray="{{gaugeStrokeDasharray uptimePercentage}}"
                    stroke-linecap="round" transform="rotate(-90 60 60)"/>
                  <text x="60" y="56" text-anchor="middle" dominant-baseline="central"
                    font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif"
                    font-size="20" font-weight="700" fill="#0f172a" class="gauge-text">{{uptimePercentageDisplay}}</text>
                  <text x="60" y="76" text-anchor="middle"
                    font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif"
                    font-size="10" fill="#64748b" class="gauge-label">UPTIME</text>
                </svg>
                <!--<![endif]-->
                <!--[if mso]>
                <p style="font-size:36px; font-weight:700; color:#0f172a; text-align:center; margin:0;">{{uptimePercentageDisplay}}</p>
                <p style="font-size:11px; color:#64748b; text-align:center; margin:4px 0 0 0; text-transform:uppercase; letter-spacing:1px;">UPTIME</p>
                <![endif]-->
              </td>
            </tr>

            <!-- STATUS SUMMARY ROW -->
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="8" border="0" style="margin:16px 0 24px 0;">
                  <tr>
                    <td align="center" width="33%" class="email-stack status-up-bg" style="background-color:#f0fdf4; border-radius:8px; padding:16px 8px;">
                      <p style="margin:0; font-size:24px; font-weight:700; color:#16a34a; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{monitorsUp}}</p>
                      <p style="margin:4px 0 0 0; font-size:11px; font-weight:600; color:#16a34a; text-transform:uppercase; letter-spacing:0.5px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">UP</p>
                    </td>
                    <td align="center" width="33%" class="email-stack status-down-bg" style="background-color:#fef2f2; border-radius:8px; padding:16px 8px;">
                      <p style="margin:0; font-size:24px; font-weight:700; color:#dc2626; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{monitorsDown}}</p>
                      <p style="margin:4px 0 0 0; font-size:11px; font-weight:600; color:#dc2626; text-transform:uppercase; letter-spacing:0.5px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">DOWN</p>
                    </td>
                    <td align="center" width="33%" class="email-stack status-degraded-bg" style="background-color:#fffbeb; border-radius:8px; padding:16px 8px;">
                      <p style="margin:0; font-size:24px; font-weight:700; color:#d97706; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{monitorsDegraded}}</p>
                      <p style="margin:4px 0 0 0; font-size:11px; font-weight:600; color:#d97706; text-transform:uppercase; letter-spacing:0.5px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">DEGRADED</p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- KEY METRICS TABLE WITH TREND ARROWS -->
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #e2e8f0; border-radius:8px; overflow:hidden;">
                  <!-- Table Header -->
                  <tr>
                    <td class="metrics-header" style="background-color:#f8fafc; padding:12px 20px; border-bottom:1px solid #e2e8f0;">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td>
                            <h3 class="metrics-header-text" style="margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; font-weight:700; color:#0f172a; text-transform:uppercase; letter-spacing:0.5px;">Key Metrics</h3>
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                  <!-- Dynamic Metric Rows -->
                  {{#each metrics}}
                  <tr>
                    <td class="detail-row-bg {{#if (isOdd @index)}}detail-row-alt{{/if}}" style="padding:12px 20px; border-bottom:1px solid #e2e8f0;{{#if (isOdd @index)}} background-color:#f8fafc;{{/if}}">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td class="detail-label" width="160" style="font-size:13px; font-weight:500; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{label}}</td>
                          <td class="detail-value" style="font-size:14px; font-weight:700; color:#1e293b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{value}}</td>
                          <td width="100" style="font-size:12px; font-weight:600; text-align:right; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; color:{{#if (eq changeDirection 'up')}}#16a34a{{else if (eq changeDirection 'down')}}#dc2626{{else}}#64748b{{/if}};">
                            {{trendArrow changeDirection}} {{changePercent}}%
                          </td>
                        </tr>
                      </table>
                    </td>
                  </tr>
                  {{/each}}
                </table>
              </td>
            </tr>

            <!-- RESPONSE TIME DISTRIBUTION -->
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="border:1px solid #e2e8f0; border-radius:8px; overflow:hidden;">
                  <!-- Table Header -->
                  <tr>
                    <td class="metrics-header" colspan="3" style="background-color:#f8fafc; padding:12px 20px; border-bottom:1px solid #e2e8f0;">
                      <h3 class="metrics-header-text" style="margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; font-weight:700; color:#0f172a; text-transform:uppercase; letter-spacing:0.5px;">Response Time Distribution</h3>
                    </td>
                  </tr>
                  <!-- Distribution Rows -->
                  {{#each responseTimeDistribution}}
                  <tr>
                    <td width="100" class="detail-label" style="padding:6px 20px; font-size:13px; font-weight:500; color:#64748b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{label}}</td>
                    <td style="padding:6px 0;">
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                        <tr>
                          <td class="bar-track" style="width:{{percentage}}%; max-width:{{percentage}}%; height:18px; background-color:{{color}}; border-radius:3px;">&nbsp;</td>
                          <td style="height:18px;">&nbsp;</td>
                        </tr>
                      </table>
                    </td>
                    <td width="50" class="detail-value" style="text-align:right; padding:6px 20px; font-size:13px; font-weight:700; color:#1e293b; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">{{count}}</td>
                  </tr>
                  {{/each}}
                </table>
              </td>
            </tr>

            <!-- TOP ALERTS (conditional) -->
            {{#if hasAlerts}}
            <tr>
              <td class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="alert-box" style="background-color:#fffbeb; border:1px solid #fde68a; border-left:4px solid #f59e0b; border-radius:0 6px 6px 0;">
                  <tr>
                    <td style="padding:16px 20px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; line-height:1.5; color:#92400e;">
                      <strong style="display:block; margin-bottom:8px;">Top Alerts</strong>
                      {{#each topAlerts}}
                      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom:6px;">
                        <tr>
                          <td width="16" valign="top" style="font-size:14px; line-height:1.5; color:#92400e; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">&bull;</td>
                          <td style="font-size:14px; line-height:1.5; color:#92400e; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;">
                            <span style="display:inline-block; padding:1px 8px; border-radius:3px; font-size:10px; font-weight:700; color:#fff; background-color:{{severityColor}}; text-transform:uppercase; margin-right:6px;">{{severity}}</span>
                            {{ruleName}} &mdash; {{count}} times (last: {{lastFired}})
                          </td>
                        </tr>
                      </table>
                      {{/each}}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            {{/if}}

            <!-- CTA BUTTON -->
            <tr>
              <td align="center" class="email-padding" style="padding:0 40px 24px 40px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td align="center" style="background-color:#0d9488; border-radius:8px;">
                      <!--[if mso]>
                      <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{reportLink}}" style="height:50px; v-text-anchor:middle; width:260px;" arcsize="16%" strokecolor="#0d9488" fillcolor="#0d9488">
                      <w:anchorlock/>
                      <center style="font-family:'Segoe UI',Roboto,sans-serif; font-size:16px; font-weight:700; color:#ffffff;">View Full Report</center>
                      </v:roundrect>
                      <![endif]-->
                      <!--[if !mso]><!-->
                      <a href="{{reportLink}}" class="btn-full-width" style="display:inline-block; padding:14px 48px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:16px; font-weight:700; color:#ffffff; background-color:#0d9488; border-radius:8px; text-decoration:none; text-align:center; mso-padding-alt:0; transition:background-color 0.2s ease;">
                        View Full Report
                      </a>
                      <!--<![endif]-->
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <!-- CLOSING -->
            <tr>
              <td class="email-padding" style="padding:0 40px 32px 40px;">
                <p class="email-text" style="margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:16px; line-height:1.6; color:#475569;">
                  Stay informed,<br>
                  <strong style="color:#0f172a;">TelemetryFlow Observability - Team</strong>
                </p>
              </td>
            </tr>

            <!-- FOOTER -->
            <tr>
              <td class="email-padding" style="padding:0 40px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
